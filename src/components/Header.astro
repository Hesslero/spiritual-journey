---
import { consultationHref, consultationHrefEs, phoneHref } from '../data/site';
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const isEs = lang === 'es';
const text = {
  practice: isEs ? 'La Práctica' : 'The Practice',
  journey: isEs ? 'El Viaje' : 'The Journey',
  nathalie: 'Nathalie',
  call: isEs ? 'Llamar' : 'Call',
  callNathalie: isEs ? 'Llamar a Nathalie' : 'Call Nathalie',
  begin: isEs ? 'Comenzar aquí' : 'Begin here',
  freeConsultation: isEs ? 'Consulta gratuita' : 'Free consultation'
};

const activeConsultationHref = isEs ? consultationHrefEs : consultationHref;
---
<header class="site-header">
  <a class="brand" href={isEs ? "/es/#top" : "#top"} aria-label={isEs ? "Nathalie Bose-Silver, inicio" : "Nathalie Bose-Silver, home"}>
    <img src="/images/spiritual-journey/spiritual-journey-logo.png" alt="" />
    <span><strong>Nathalie</strong><small>Bose-Silver</small></span>
  </a>
  <nav class="main-nav" aria-label={isEs ? "Navegación principal" : "Main navigation"}>
    <a href={isEs ? "/es/#practice" : "#practice"}>{text.practice}</a>
    <a href={isEs ? "/es/#journey" : "#journey"}>{text.journey}</a>
    <a href={isEs ? "/es/#nathalie" : "#nathalie"}>{text.nathalie}</a>
  </nav>
  <div class="header-actions">
    <a class="call-link" href={phoneHref}>{text.call}</a>
    <a class="header-cta" href={activeConsultationHref}>{text.begin} <span>↗</span></a>
    {isEs ? (
      <a href="/" class="lang-switch" aria-label="Switch to English">EN</a>
    ) : (
      <a href="/es/" class="lang-switch" aria-label="Cambiar a Español">ES</a>
    )}
  </div>
  <details class="menu">
    <summary aria-label={isEs ? "Abrir menú" : "Open menu"}><i></i><i></i></summary>
    <nav>
      <a href={isEs ? "/es/#practice" : "#practice"}>{text.practice}</a>
      <a href={isEs ? "/es/#journey" : "#journey"}>{text.journey}</a>
      <a href={isEs ? "/es/#nathalie" : "#nathalie"}>{text.nathalie}</a>
      <a href={phoneHref}>{text.callNathalie}</a>
      <a href={activeConsultationHref}>{text.freeConsultation}</a>
      {isEs ? (
        <a href="/" class="lang-switch-mobile">English (EN)</a>
      ) : (
        <a href="/es/" class="lang-switch-mobile">Español (ES)</a>
      )}
    </nav>
  </details>
</header>
<script>
  const details = document.querySelector('details.menu');
  if (details) {
    const navLinks = details.querySelectorAll('nav a');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        details.removeAttribute('open');
      });
    });
  }
</script>

