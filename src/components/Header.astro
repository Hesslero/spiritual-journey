---
import { consultationHref, consultationHrefEs } from '../data/site';
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;

const isEs = lang === 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const text = {
  practice: isEs ? 'La Práctica' : 'The Practice',
  journey: isEs ? 'El Viaje' : 'The Journey',
  nathalie: 'Nathalie',
  begin: isEs ? 'Comenzar aquí' : 'Begin here',
  freeConsultation: isEs ? 'Consulta gratuita' : 'Free consultation'
};

const activeConsultationHref = isEs ? consultationHrefEs : consultationHref;
const homeHref      = isEs ? `${base}/es/` : `${base}/`;
const enHref        = `${base}/`;
const esHref        = `${base}/es/`;
const logoSrc       = `${base}/images/spiritual-journey/spiritual-journey-logo.png`;
const practiceHref  = isEs ? `${base}/es/#practice`  : `${base}/#practice`;
const journeyHref   = isEs ? `${base}/es/#journey`   : `${base}/#journey`;
const nathalieHref  = isEs ? `${base}/es/#nathalie`  : `${base}/#nathalie`;
---
<header class="site-header">
  <a class="brand" href={homeHref} aria-label={isEs ? "Nathalie Bose-Silver, inicio" : "Nathalie Bose-Silver, home"}>
    <img src={logoSrc} alt="" />
    <span><strong>Nathalie</strong><small>Bose-Silver</small></span>
  </a>
  <nav class="main-nav" aria-label={isEs ? "Navegación principal" : "Main navigation"}>
    <a href={practiceHref}>{text.practice}</a>
    <a href={journeyHref}>{text.journey}</a>
    <a href={nathalieHref}>{text.nathalie}</a>
  </nav>
  <div class="header-actions">
    <a class="header-cta" href={activeConsultationHref}>{text.begin} <span>↗</span></a>
    {isEs ? (
      <a href={enHref} class="lang-switch" aria-label="Switch to English">EN</a>
    ) : (
      <a href={esHref} class="lang-switch" aria-label="Cambiar a Español">ES</a>
    )}
  </div>
  <details class="menu">
    <summary aria-label={isEs ? "Abrir menú" : "Open menu"}><i></i><i></i></summary>
    <nav>
      <a href={practiceHref}>{text.practice}</a>
      <a href={journeyHref}>{text.journey}</a>
      <a href={nathalieHref}>{text.nathalie}</a>
      <a href={activeConsultationHref}>{text.freeConsultation}</a>
      {isEs ? (
        <a href={enHref} class="lang-switch-mobile">English (EN)</a>
      ) : (
        <a href={esHref} class="lang-switch-mobile">Español (ES)</a>
      )}
    </nav>
  </details>
</header>
<script>
  const details = document.querySelector('details.menu');
  if (details) {
    const navLinks = details.querySelectorAll('nav a');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        details.removeAttribute('open');
      });
    });
  }
</script>

