---
import Header from "../../components/Header.astro";
import Icon from "../../components/Icon.astro";
import {
  approachEs,
  consultationHrefEs,
  email,
  expectationsEs,
} from "../../data/site";
import "../../styles/global.css";
const year = new Date().getFullYear();
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nathalie Bose-Silver",
  jobTitle: "Spiritual Director",
  email,
  areaServed: ["Oviedo, Florida", "Winter Park, Florida"],
  knowsLanguage: ["English", "Spanish"],
};
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://sacred-guides.com",
);
---

<!doctype html>
<html lang="es">
  <head
    ><meta charset="UTF-8" /><meta
      name="viewport"
      content="width=device-width"
    /><title>
      Nathalie Bose-Silver | Acompañamiento y Dirección Espiritual | Orlando, FL
    </title><meta
      name="description"
      content="Acompañamiento y dirección espiritual en Orlando, FL. Un espacio de oración silencioso para percibir el movimiento de la gracia y discernir tu camino."
    /><link rel="canonical" href={canonicalURL} /><link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    /><link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    /><link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    /><meta
      property="og:title"
      content="Nathalie Bose-Silver | Acompañamiento y Dirección Espiritual"
    /><meta
      property="og:description"
      content="Un espacio de oración para percibir la gracia y discernir tu camino."
    /><meta property="og:type" content="website" /><meta
      property="og:image"
      content="/images/spiritual-journey/spiritual-journey-logo.png"
    /><link
      rel="icon"
      type="image/png"
      href={`${base}/images/spiritual-journey/spiritual-journey-logo.png`}
    /><script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    /><script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-YWHMGV3SF6"
    ></script><script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-YWHMGV3SF6");
    </script></head
  >
  <body id="top"
    ><a class="skip" href="#main">Saltar al contenido</a><Header lang="es" />
    <main id="main">
      <section class="hero">
        <div class="hero-index" aria-hidden="true">
          <i></i><small>Bienvenido</small>
        </div>
        <div class="hero-copy">
          <p class="kicker">Acompañamiento espiritual · Inglés y Español</p><h1>
            Un camino más silencioso para escuchar lo que tu <em>corazón</em> ya sabe.
          </h1><p class="hero-lead">
            Aléjate del ruido. Entra en una conversación íntima y de oración
            para percibir el movimiento de Dios y mirar tu vida con claridad,
            valor y gracia.
          </p><div class="hero-actions">
            <a class="primary-link" href={consultationHrefEs}
              >Conversación gratuita de 30 minutos <span>↗</span></a>
          </div><p class="fee-note">
            Consulta inicial gratuita · Se aplica tarifa en sesiones regulares
          </p>
        </div>
        <div class="hero-visual">
          <div class="orbit orbit-one"></div><div class="orbit orbit-two">
          </div><img
            src={`${base}/images/spiritual-journey/spiritual-journey-logo.png`}
            width="1024"
            height="1024"
            alt="Emblema de Spiritual Journey con un sendero sinuoso, mariposas, manos sosteniendo una llama y una paloma."
          /><p>
            <span>✦</span>Una pausa sagrada<br />para tu camino por recorrer
          </p>
        </div>
        <a class="scroll-cue" href="#practice"
          ><span>Desliza para explorar</span><i>↓</i></a
        >
      </section>

      <section class="manifesto" id="practice">
        <div class="butterfly butterfly-1" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-2" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-3" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-4" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-5" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-6" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="section-number">La práctica</div><div
          class="manifesto-title"
        >
          <p>El acompañamiento espiritual es</p><h2>
            No es un consejo.<br />No es terapia.<br /><em
              >Es atención sagrada.</em>
          </h2><figure class="practice-image">
            <img
              src={`${base}/images/spiritual-journey/spiritual-practice.png`}
              alt="Una Biblia abierta y una vela encendida sobre una mesa de madera rústica, sugiriendo un espacio de oración y recogimiento."
              loading="lazy"
            /><figcaption>
              Un espacio para escuchar más allá del ruido.
            </figcaption>
          </figure>
        </div><div class="manifesto-copy">
          <p>
            Es una conversación centrada en tu relación con Dios: un espacio
            para desacelerar, reflexionar, orar y estar atento a la gracia en la
            vida cotidiana.
          </p><p>
            Nathalie no te diagnostica ni te impone respuestas. Ella te acompaña
            a reconocer la presencia divina dentro y alrededor de ti, y a
            discernir el camino que ya se está abriendo.
          </p><aside>
            “Un director espiritual es aquel que ayuda a otro a reconocer y
            seguir las inspiraciones de la gracia.” <cite>— Thomas Merton</cite>
          </aside>
        </div>
      </section>

      <section class="path-section" id="journey">
        <div class="path-heading">
          <div>
            <span class="section-number">El viaje</span><h2>
              Cuatro movimientos.<br />Un camino por descubrir.
            </h2>
          </div><p>
            Conversaciones mensuales de una hora centradas en tu vida, no en una
            fórmula.
          </p>
        </div><div class="path-layout">
          <div class="path-line" aria-hidden="true">
            <span class="path-progress"></span>
          </div>{
            expectationsEs.map(([icon, title, text], i) => (
              <article class="path-step">
                <>
                  <div class="step-icon">
                    <Icon name={icon} />
                  </div>
                  <div>
                    <>
                      <h3>{title}</h3>
                      <p>{text}</p>
                    </>
                  </div>
                </>
              </article>
            ))
          }
        </div>
      </section>

      <section class="approach">
        <div class="approach-sticky">
          <span class="section-number">El enfoque</span><h2>
            Acogido con cuidado.<br />Guiado por la gracia.
          </h2><p>
            Cada sesión es una invitación a hacer una pausa y escuchar
            profundamente lo que se mueve dentro de tu corazón.
          </p>
        </div><div class="approach-panels">
          {
            approachEs.map(([title, text], i) => (
              <article>
                <>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </>
              </article>
            ))
          }
        </div>
      </section>

      <section class="profile" id="nathalie">
        <figure class="profile-mark profile-photo">
          <img
            src={`${base}/images/spiritual-journey/profile-pic.png`}
            alt="Retrato de Nathalie Bose-Silver sonriendo con una chaqueta naranja."
            loading="lazy"
          /><figcaption>Presencia compasiva · Escucha en oración</figcaption>
        </figure><div class="profile-copy">
          <span class="section-number">Tu compañera</span><h2>
            Conoce a tu Acompañante Espiritual,<br />Nathalie Bose-Silver.
          </h2><p class="profile-intro">
            Una directora espiritual profesional certificada, arraigada en la fe
            católica y abierta a la historia sagrada de cada persona.
          </p><div class="profile-columns">
            <p>
              Nathalie completó el Programa de Presencia Sagrada en el Centro
              San Pedro, un ministerio de Mayslake Ministries, y es miembro de
              Spiritual Directors International.
            </p><p>
              Su experiencia incluye formación en la fe de adultos y jóvenes, y
              la fundación de un ministerio sin fines de lucro para la
              elaboración de rosarios, apoyando una oración y devoción más
              profundas.
            </p>
          </div><div class="credentials">
            <span>Directora Espiritual Certificada</span><span
              >Inglés y Español</span
            ><span>Miembro de la SDI</span>
          </div>
        </div>
      </section>

      <section class="meeting" id="meeting-section">
        <div class="meeting-intro">
          <span class="section-number">Dónde nos reunimos</span>
          <h2>Dondequiera que puedas<br />estar plenamente presente.</h2>
        </div>

        <form class="meeting-form" data-contact-form data-lang="es">
          <div class="form-heading form-field-wide">
            <span>Contacta a Nathalie</span>
            <h3>Envía un mensaje para comenzar tu camino.</h3>
            <p>Los campos marcados con un asterisco (*) son obligatorios.</p>
          </div>
          <div class="form-field">
            <label for="contact-name">Nombre <span aria-hidden="true">*</span></label>
            <input id="contact-name" name="name" type="text" autocomplete="name" placeholder="Ej.: María González" pattern="[A-Za-zÀ-ÖØ-öø-ÿĀ-ž' -]{2,100}" maxlength="100" title="Escribe tu nombre utilizando únicamente letras." required />
          </div>
          <div class="form-field">
            <label for="contact-email">Correo electrónico <span aria-hidden="true">*</span></label>
            <input id="contact-email" name="email" type="email" autocomplete="email" placeholder="Ej.: maria@ejemplo.com" maxlength="254" title="Escribe un correo válido, por ejemplo, maria@ejemplo.com." required />
          </div>
          <div class="form-field form-field-wide">
            <label for="contact-meeting">¿Cómo prefieres reunirte? <span aria-hidden="true">*</span></label>
            <select id="contact-meeting" name="meeting" required>
              <option value="" selected disabled>Selecciona una opción</option>
              <option value="Zoom">Zoom</option>
              <option value="Teléfono">Teléfono</option>
              <option value="Presencial">Presencial</option>
            </select>
          </div>
          <div class="form-field form-field-wide">
            <label for="contact-message">¿Cómo puedo acompañarte?</label>
            <textarea id="contact-message" name="message" rows="7" maxlength="3000">Hola Nathalie:

Me interesa conocer más sobre el acompañamiento espiritual. Me gustaría recibir apoyo con...

Los días u horarios que generalmente me funcionan mejor son...</textarea>
          </div>
          <div class="form-honeypot" aria-hidden="true">
            <label for="contact-website">Sitio web</label>
            <input id="contact-website" name="_honey" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="form-submit form-field-wide">
            <p>Tu información se utilizará únicamente para responder a esta consulta.</p>
            <button type="submit">Iniciar la conversación <span>→</span></button>
          </div>
          <p class="form-status form-field-wide" role="status" aria-live="polite"></p>
          <div class="form-success-popup" data-success-popup hidden>
            <div class="success-popup-card" role="dialog" aria-modal="true" aria-labelledby="success-title-es" aria-describedby="success-message-es">
              <span class="success-popup-icon" aria-hidden="true">✓</span>
              <span class="success-popup-kicker">Mensaje enviado</span>
              <h3 id="success-title-es">Gracias por comunicarte.</h3>
              <p id="success-message-es">Tu mensaje se envió correctamente. Nathalie se pondrá en contacto contigo pronto.</p>
              <button type="button" data-close-success>Cerrar</button>
            </div>
          </div>
        </form>
      </section>

      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
          const popup = form?.querySelector<HTMLElement>("[data-success-popup]");
          const closePopup = form?.querySelector<HTMLButtonElement>("[data-close-success]");
          const hidePopup = () => {
            if (popup) popup.hidden = true;
          };
          closePopup?.addEventListener("click", hidePopup);
          popup?.addEventListener("click", (event) => {
            if (event.target === popup) hidePopup();
          });
          document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && popup && !popup.hidden) hidePopup();
          });
          form?.addEventListener("submit", async (event) => {
            event.preventDefault();
            const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
            const status = form.querySelector<HTMLElement>(".form-status");
            const data = new FormData(form);
            if (button) { button.disabled = true; button.textContent = "Enviando…"; }
            if (status) { status.textContent = ""; status.className = "form-status form-field-wide"; }
            try {
              const response = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  ...Object.fromEntries(data),
                  language: "es",
                }),
              });
              if (response.status === 429) {
                if (status) {
                  status.textContent = "Solo puedes enviar un mensaje cada 24 horas. Inténtalo nuevamente mañana.";
                  status.classList.add("error");
                }
                return;
              }
              if (!response.ok) throw new Error("Request failed");
              form.reset();
              if (status) { status.textContent = "Gracias. Tu mensaje ha sido enviado."; status.classList.add("success"); }
              if (popup) { popup.hidden = false; closePopup?.focus(); }
            } catch {
              if (status) { status.textContent = "No pudimos enviar tu mensaje. Inténtalo de nuevo en unos momentos."; status.classList.add("error"); }
            } finally {
              if (button) { button.disabled = false; button.innerHTML = "Iniciar la conversación <span>→</span>"; }
            }
          });
        });
      </script>

      <section class="contact" id="contact">
        <div class="contact-symbol" aria-hidden="true">✦</div><p>
          Comienza con una conversación de cortesía
        </p><h2>Comienza Tu Camino Espiritual Hoy.</h2><div
          class="contact-actions"
        >
          <a href={consultationHrefEs}>Escribir a Nathalie <span>↗</span></a>
        </div><p
          class="fee-note"
          style="color:rgba(255,244,217,0.65);margin-top:18px;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;"
        >
          Consulta inicial gratuita · Se aplica tarifa en sesiones regulares
        </p><div class="contact-meta">
          <span>{email}</span><span>Inglés y Español</span><span
            >Zoom · En Persona</span>
        </div>
      </section>
      <a
        href="#top"
        id="back-to-top"
        class="back-to-top"
        aria-label="Subir al inicio"
      >
        <svg viewBox="0 0 24 24"
          ><path d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8z"
          ></path></svg
        >
      </a>
    </main>
    <footer>
      <div>
        <strong>Nathalie Bose-Silver</strong><span>Directora Espiritual</span>
      </div><nav>
        <a href="#practice">Práctica</a><a href="#journey">Viaje</a><a
          href="#nathalie">Acerca de</a
        ><a href="#contact">Contacto</a>
      </nav><p>
        © {year} Nathalie Bose-Silver.<br />El acompañamiento espiritual no
        sustituye la consejería, la psicoterapia, la atención médica ni los
        servicios de emergencia.
      </p>
    </footer>
    <script>
      import "../../scripts/animations";

      const backToTop = document.getElementById("back-to-top");
      window.addEventListener("scroll", () => {
        if (window.scrollY > 400) {
          backToTop?.classList.add("visible");
        } else {
          backToTop?.classList.remove("visible");
        }
      });
    </script></body>
</html>
