---
import Header from "../components/Header.astro";
import Icon from "../components/Icon.astro";
import { approach, consultationHref, email, expectations } from "../data/site";
import "../styles/global.css";
const year = new Date().getFullYear();
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nathalie Bose-Silver",
  jobTitle: "Spiritual Director",
  email,
  areaServed: ["Oviedo, Florida", "Winter Park, Florida"],
  knowsLanguage: ["English", "Spanish"],
};
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://sacred-guides.com",
);
---

<!doctype html>
<html lang="en">
  <head
    ><meta charset="UTF-8" /><meta
      name="viewport"
      content="width=device-width"
    /><title>
      Nathalie Bose-Silver | Certified Spiritual Director | Orlando, FL
    </title><meta
      name="description"
      content="Spiritual direction and companionship in Orlando, FL. A quiet, prayerful space to notice the movement of grace and discern your path."
    /><link rel="canonical" href={canonicalURL} /><link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    /><link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    /><link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    /><meta
      property="og:title"
      content="Nathalie Bose-Silver | Spiritual Direction & Companion"
    /><meta
      property="og:description"
      content="A prayerful space to notice grace and discern your path."
    /><meta property="og:type" content="website" /><meta
      property="og:image"
      content="/images/spiritual-journey/spiritual-journey-logo.png"
    /><link
      rel="icon"
      type="image/png"
      href={`${base}/images/spiritual-journey/spiritual-journey-logo.png`}
    /><script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    /><script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-YWHMGV3SF6"
    ></script><script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-YWHMGV3SF6");
    </script></head
  >
  <body id="top"
    ><a class="skip" href="#main">Skip to content</a><Header />
    <main id="main">
      <section class="hero">
        <div class="hero-index" aria-hidden="true">
          <i></i><small>Welcome</small>
        </div>
        <div class="hero-copy">
          <p class="kicker">Spiritual direction · English & Spanish</p><h1>
            A quieter way to hear what your <em>heart</em> already knows.
          </h1><p class="hero-lead">
            Leave the noise behind and enter a quiet place of prayer, where
            God’s gentle movement becomes visible and your own life rises before
            you with clarity, courage, and grace.
          </p><div class="hero-actions">
            <a class="primary-link" href={consultationHref}
              >Free 30-minute conversation <span>↗</span></a>
          </div><p class="fee-note">
            Free initial consultation · Fee applies for ongoing sessions
          </p>
        </div>
        <div class="hero-visual">
          <div class="orbit orbit-one"></div><div class="orbit orbit-two">
          </div><img
            src={`${base}/images/spiritual-journey/spiritual-journey-logo.png`}
            width="1024"
            height="1024"
            alt="Spiritual Journey emblem featuring a winding path, butterflies, hands holding a flame, and a dove."
          /><p><span>✦</span>A sacred pause<br />for your unfolding path</p>
        </div>
        <a class="scroll-cue" href="#practice"
          ><span>Scroll to explore</span><i>↓</i></a
        >
      </section>

      <section class="manifesto" id="practice">
        <div class="butterfly butterfly-1" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-2" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-3" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-4" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-5" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="butterfly butterfly-6" aria-hidden="true">
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 10c-.7-2-3-5.5-6-5.5C3 4.5 1 6.5 1 9.5c0 3 2.5 5.5 5.5 6.5-.5 1-1.5 2.5-3 3.5 0 0 2-.5 3.5-2 .5.5 1 1 1.5 1s1-.5 1.5-1c1.5 1.5 3.5 2 3.5 2-1.5-1-2.5-2.5-3-3.5 3-1 5.5-3.5 5.5-6.5 0-3-2-5-5-5-3 0-5.3 3.5-6 5.5z"
            ></path></svg
          >
        </div>
        <div class="section-number">The practice</div><div
          class="manifesto-title"
        >
          <p>Spiritual direction is</p><h2>
            Not advice.<br />Not therapy.<br /><em>Sacred attention.</em>
          </h2><figure class="practice-image">
            <img
              src={`${base}/images/spiritual-journey/spiritual-practice.png`}
              alt="An open Bible and a warm lit candle on a rustic wooden table, suggesting a prayerful and sacred space."
              loading="lazy"
            /><figcaption>A space to listen beyond the noise.</figcaption>
          </figure>
        </div><div class="manifesto-copy">
          <p>
            It is a conversation centered on your relationship with God—a place
            to slow down, reflect, pray, and become attentive to grace in
            ordinary life.
          </p><p>
            Nathalie does not diagnose or hand you answers. She accompanies you
            as you recognize the Divine within and around you, and discern the
            path that is already unfolding.
          </p><aside>
            “A spiritual director is one who helps another to recognize and
            follow the inspirations of grace.” <cite>— Thomas Merton</cite>
          </aside>
        </div>
      </section>

      <section class="path-section" id="journey">
        <div class="path-heading">
          <div>
            <span class="section-number">The journey</span><h2>
              Four movements.<br />One unfolding path.
            </h2>
          </div><p>
            Monthly, one-hour conversations shaped around your life—not a
            formula.
          </p>
        </div><div class="path-layout">
          <div class="path-line" aria-hidden="true">
            <span class="path-progress"></span>
          </div>{
            expectations.map(([icon, title, text], i) => (
              <article class="path-step">
                <>
                  <div class="step-icon">
                    <Icon name={icon} />
                  </div>
                  <div>
                    <>
                      <h3>{title}</h3>
                      <p>{text}</p>
                    </>
                  </div>
                </>
              </article>
            ))
          }
        </div>
      </section>

      <section class="approach">
        <div class="approach-sticky">
          <span class="section-number">The approach</span><h2>
            Held with care.<br />Guided by grace.
          </h2><p>
            Every session is an invitation to pause and listen deeply to what is
            moving within your heart.
          </p>
        </div><div class="approach-panels">
          {
            approach.map(([title, text], i) => (
              <article>
                <>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </>
              </article>
            ))
          }
        </div>
      </section>

      <section class="profile" id="nathalie">
        <figure class="profile-mark profile-photo">
          <img
            src={`${base}/images/spiritual-journey/profile-pic.png`}
            alt="Portrait of Nathalie Bose-Silver smiling in an orange jacket."
            loading="lazy"
          /><figcaption>
            Compassionate presence · Prayerful listening
          </figcaption>
        </figure><div class="profile-copy">
          <span class="section-number">Your companion</span><h2>
            Meet Your Spiritual Companion,<br />Nathalie Bose-Silver.
          </h2><p class="profile-intro">
            A certified professional spiritual director rooted in the Catholic
            faith and open to the unique sacred story of every person.
          </p><div class="profile-columns">
            <p>
              Nathalie completed the Sacred Presence Program at San Pedro
              Center, a ministry of Mayslake Ministries, and is a member of
              Spiritual Directors International.
            </p><p>
              Her experience includes adult and youth faith formation and
              founding a nonprofit rosary-making ministry supporting deeper
              devotion and prayer.
            </p>
          </div><div class="credentials">
            <span>Certified Spiritual Director</span><span
              >English & Spanish</span
            ><span>SDI Member</span>
          </div>
        </div>
      </section>

      <section class="meeting" id="meeting-section">
        <div class="meeting-intro">
          <span class="section-number">Where we meet</span>
          <h2>Wherever you can<br />be fully present.</h2>
        </div>

        <form class="meeting-form" data-contact-form data-lang="en">
          <div class="form-heading form-field-wide">
            <span>Contact Nathalie</span>
            <h3>Send a message to begin your journey.</h3>
            <p>Fields marked with an asterisk (*) are required.</p>
          </div>
          <div class="form-field">
            <label for="contact-name">Name <span aria-hidden="true">*</span></label>
            <input id="contact-name" name="name" type="text" autocomplete="name" placeholder="e.g., Maria Gonzalez" pattern="[A-Za-zÀ-ÖØ-öø-ÿĀ-ž' -]{2,100}" maxlength="100" title="Please enter your name using letters only." required />
          </div>
          <div class="form-field">
            <label for="contact-email">Email <span aria-hidden="true">*</span></label>
            <input id="contact-email" name="email" type="email" autocomplete="email" placeholder="e.g., maria@example.com" maxlength="254" title="Please enter a valid email address, such as maria@example.com." required />
          </div>
          <div class="form-field form-field-wide">
            <label for="contact-meeting">How would you prefer to meet? <span aria-hidden="true">*</span></label>
            <select id="contact-meeting" name="meeting" required>
              <option value="" selected disabled>Select an option</option>
              <option value="Zoom">Zoom</option>
              <option value="Phone">Phone</option>
              <option value="In person">In person</option>
            </select>
          </div>
          <div class="form-field form-field-wide">
            <label for="contact-message">How can I accompany you?</label>
            <textarea id="contact-message" name="message" rows="7" maxlength="3000">Hello Nathalie,

I’m interested in learning more about spiritual direction. I would appreciate support with...

The days or times that usually work best for me are...</textarea>
          </div>
          <div class="form-honeypot" aria-hidden="true">
            <label for="contact-website">Website</label>
            <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="form-submit form-field-wide">
            <p>Your information is used only to respond to this inquiry.</p>
            <button type="submit">Begin the conversation <span>→</span></button>
          </div>
          <p class="form-status form-field-wide" role="status" aria-live="polite"></p>
        </form>
      </section>

      <script>
        document.addEventListener("DOMContentLoaded", () => {
          const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
          form?.addEventListener("submit", async (event) => {
            event.preventDefault();
            const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
            const status = form.querySelector<HTMLElement>(".form-status");
            const data = new FormData(form);
            if (button) { button.disabled = true; button.textContent = "Sending…"; }
            if (status) { status.textContent = ""; status.className = "form-status form-field-wide"; }
            try {
              const response = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ ...Object.fromEntries(data), language: "en" }),
              });
              if (!response.ok) throw new Error("Request failed");
              form.reset();
              if (status) { status.textContent = "Thank you. Your message has been sent."; status.classList.add("success"); }
            } catch {
              if (status) { status.textContent = "We couldn't send your message. Please try again shortly."; status.classList.add("error"); }
            } finally {
              if (button) { button.disabled = false; button.innerHTML = "Begin the conversation <span>→</span>"; }
            }
          });
        });
      </script>

      <section class="contact" id="contact">
        <div class="contact-symbol" aria-hidden="true">✦</div><p>
          Begin with a complimentary conversation
        </p><h2>Begin Your Spiritual Journey Today.</h2><div
          class="contact-actions"
        >
          <a href={consultationHref}>Email Nathalie <span>↗</span></a>
        </div><p
          class="fee-note"
          style="color:rgba(255,244,217,0.65);margin-top:18px;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;"
        >
          Free initial consultation · Fee applies for ongoing sessions
        </p><div class="contact-meta">
          <span>{email}</span><span>English & Spanish</span><span
            >Zoom · In person</span>
        </div>
      </section>
      <a
        href="#top"
        id="back-to-top"
        class="back-to-top"
        aria-label="Back to top"
      >
        <svg viewBox="0 0 24 24"
          ><path d="M4 12l1.41 1.41L11 7.83V20h2V7.83l5.58 5.59L20 12l-8-8z"
          ></path></svg
        >
      </a>
    </main>
    <footer>
      <div>
        <strong>Nathalie Bose-Silver</strong><span>Spiritual Director</span>
      </div><nav>
        <a href="#practice">Practice</a><a href="#journey">Journey</a><a
          href="#nathalie">About</a
        ><a href="#contact">Contact</a>
      </nav><p>
        © {year} Nathalie Bose-Silver.<br />Spiritual direction is not a
        substitute for counseling, psychotherapy, medical care, or emergency
        services.
      </p>
    </footer>
    <script>
      import "../scripts/animations";

      const backToTop = document.getElementById("back-to-top");
      window.addEventListener("scroll", () => {
        if (window.scrollY > 400) {
          backToTop?.classList.add("visible");
        } else {
          backToTop?.classList.remove("visible");
        }
      });
    </script></body>
</html>
